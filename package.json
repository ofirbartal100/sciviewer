{
  "name": "sciviewer",
  "publisher": "Ofiri",
  "displayName": "SciViewer",
  "description": "Seamless Python plot visualization with zero-setup auto-injection. Automatically captures matplotlib plots in VS Code, eliminating X11 forwarding issues for remote development.",
  "icon": "icon.png",
  "version": "0.2.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ofirbartal100/sciviewer"
  },
  "homepage": "https://github.com/ofirbartal100/sciviewer#readme",
  "bugs": {
    "url": "https://github.com/ofirbartal100/sciviewer/issues"
  },
  "keywords": [
    "python",
    "matplotlib",
    "plot",
    "visualization",
    "data science",
    "remote development",
    "jupyter",
    "scientific"
  ],
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Visualization",
    "Data Science",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1e3a5f",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sciviewer.open",
        "title": "Open SciViewer"
      },
      {
        "command": "sciviewer.toggleAutoInjection",
        "title": "SciViewer: Toggle Auto-Injection"
      },
      {
        "command": "sciviewer.injectNow",
        "title": "SciViewer: Inject Into Current Python Session"
      },
      {
        "command": "sciviewer.showStatus",
        "title": "SciViewer: Show Injection Status"
      }
    ],
    "configuration": {
      "title": "SciViewer",
      "properties": {
        "sciviewer.autoInject": {
          "type": "boolean",
          "default": true,
          "description": "Automatically inject SciViewer patch when Python files are opened or executed"
        },
        "sciviewer.autoOpenPanel": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open SciViewer panel when first plot is detected"
        },
        "sciviewer.detectJupyter": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect and patch Jupyter notebook kernels"
        },
        "sciviewer.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show SciViewer status in the status bar"
        },
        "sciviewer.injectionMethod": {
          "type": "string",
          "enum": ["automatic", "manual", "smart"],
          "default": "smart",
          "description": "How to inject the monkey patch: automatic (always), manual (never), smart (context-aware)"
        }
      }
    },
    "activationEvents": [
      "onLanguage:python",
      "onLanguage:jupyter",
      "onStartupFinished"
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && cp -r src/assets out",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "@types/mocha": "^10.0.7",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "eslint": "^9.9.1",
    "typescript": "^5.5.4",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  }
}
